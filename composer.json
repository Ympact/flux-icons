{
    "name": "ympact/flux-icons",
    "description": "A package to provide icons from different vendors for Livewire Flux.",
    "keywords": ["flux", "laravel", "livewire", "components", "ui", "icons"],
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "livewire/flux": "^1.0|^2.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/view": "^10.0|^11.0|^12.0",
        "symfony/console": "^6.0|^7.0",
        "laravel/prompts": "^0.1|^0.2|^0.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0|^10.0|^11.0|^12.0",
        "mockery/mockery": "^1.6|^2.0",
        "orchestra/testbench": "^9.5|^10.0",
        "livewire/blaze": "^1.0|1.0.0@beta",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-browser": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",        
        "laravel/pint": "^1.26",
        "phpstan/phpstan": "^2.1",
        "larastan/larastan": "^3.7"
    },
    "license": "MIT",
    "scripts": {
        "test": "pest"
    },
    "autoload": {
        "psr-4": {
            "Ympact\\FluxIcons\\": "src/"
        },
        "files": [
            "src/helpers.php",
            "src/functions.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ympact\\FluxIcons\\FluxIconsServiceProvider"
            ]
        }
    },
    "authors": [
        {
            "name": "Maurits",
            "email": "maurits@ympact-technologies.nl"
        }
    ],
    "minimum-stability": "stable",
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
